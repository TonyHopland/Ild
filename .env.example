ILD_USERNAME=admin
ILD_PASSWORD=your-secure-password-here
ILD_LOG_LEVEL=Warning
# Log level for the WorkItem Server console; defaults to ILD_LOG_LEVEL.
# WORKITEM_LOG_LEVEL=
# Agent commits default to your host ~/.gitconfig (mounted read-only). Point
# GIT_CONFIG at a different file, or override the identity by uncommenting the
# lines below. Author and committer are independent: set both pairs to the same
# value for one identity, or to different values (e.g. you as author, a bot as
# committer). Any pair you leave unset falls back to the host .gitconfig.
GIT_CONFIG=~/.gitconfig
# GIT_AUTHOR_NAME=Your Name
# GIT_AUTHOR_EMAIL=you@example.com
# GIT_COMMITTER_NAME=Your Name
# GIT_COMMITTER_EMAIL=you@example.com
# Shared secret between the ILD app and the WorkItem Server. REQUIRED — there is
# no default. Generate a strong value, e.g.: openssl rand -hex 32
WORKITEM_API_KEYS=
# Encryption-at-rest key for provider API keys and webhook secrets stored in the
# database. Optional but strongly recommended for any non-local deployment. When
# unset, those secrets are stored in plaintext. Any non-empty string works; use a
# high-entropy value, e.g.: openssl rand -hex 32
# WARNING: losing this key makes already-encrypted secrets unrecoverable — back it up.
ILD_SECRET_KEY=

# Base URL agents and the MCP server use to call back into the ILD API.
# ILD_API_URL=http://localhost:8080
# URL and API key used to auto-seed the global WorkItem Server connection.
# The API key defaults to WORKITEM_API_KEYS when unset.
# ILD_WORKITEM_SERVER_URL=http://workitem-server:8081
# ILD_WORKITEM_SERVER_API_KEY=
# Comma-separated CORS origins allowed to call the ILD API.
# ILD_ALLOWED_ORIGINS=

WITH_OPENCODE=1
WITH_PI=1
WITH_CLAUDE_CODE=1
WITH_NODE=1
WITH_DOTNET_SDK=1
# docker-compose defaults WITH_CHROME to 1 when the variable is unset; this
# example keeps it off to slim the image. Set to 1 if agents need a browser.
WITH_CHROME=0
WITH_CERTS=0

# PostgreSQL connection strings, only used when running the apps directly
# (docker compose sets its own connection strings and ignores these)
# ILD_DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=IldCore;Username=ild_core;Password=ild_core_password
# WORKITEM_DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=IldWorkitems;Username=ild_workitems;Password=ild_workitems_password

# Build-time toolchain versions. Use a specific tag (e.g. 24-alpine, 10.0)
# or "latest" to pull the newest image / channel.
NODE_VERSION=24-alpine
DOTNET_VERSION=10.0
# Used only when WITH_NODE=1 / WITH_DOTNET_SDK=1 to install dev tools into
# the runtime image. Set to "latest" to fetch the newest available.
NODE_RUNTIME_VERSION=24.15.0
DOTNET_SDK_CHANNEL=10.0

# Set WITH_CERTS=1 and place .crt or .pem files in the local certs/ directory
# before running docker compose build to bake custom CA certificates into the
# image. The certs/ directory is gitignored so certificates are never committed.
