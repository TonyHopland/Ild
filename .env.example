ILD_USERNAME=admin
ILD_PASSWORD=your-secure-password-here
ILD_LOG_LEVEL=Information
GIT_CONFIG=~/.gitconfig
WORKITEM_API_KEY=test-api-key-123
WITH_OPENCODE=1
WITH_NODE=1
WITH_DOTNET_SDK=1
WITH_CHROME=0

# Build-time toolchain versions. Use a specific tag (e.g. 22-alpine, 10.0)
# or "latest" to pull the newest image / channel.
NODE_VERSION=22-alpine
DOTNET_VERSION=10.0
# Used only when WITH_NODE=1 / WITH_DOTNET_SDK=1 to install dev tools into
# the runtime image. Set to "latest" to fetch the newest available.
NODE_RUNTIME_VERSION=24.15.0
DOTNET_SDK_CHANNEL=10.0

# Place .crt or .pem files in the certs/ directory to install custom CA
# certificates into the container's trust store at startup. The certs/
# directory is gitignored so certificates are never committed.
